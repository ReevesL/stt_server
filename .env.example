HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Number of CPU threads for Whisper (CTranslate2) and PyTorch (diarization).
# 0 = use all available cores (default).
CPU_THREADS=0

# Number of concurrent transcription jobs. Each job uses CPU_THREADS threads,
# so MAX_WORKERS * CPU_THREADS should not exceed your core count.
MAX_WORKERS=1
